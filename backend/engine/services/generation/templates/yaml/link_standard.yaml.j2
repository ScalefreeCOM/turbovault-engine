{# Link Model YAML Schema Template #}
version: 2

models:
  - name: {{ link_name }}
    description: "{{ 'Standard' if link_type == 'standard' else 'Non-Historized' }} link for {{ link_name }}"
    config:
      tags: ['link', 'raw_vault'{{ ", '" ~ group ~ "'" if group }}]
    columns:
      - name: {{ hashkey.hashkey_name }}
        description: "Link hash key"
        data_tests:
          - unique
          - not_null
      {%- for hub_ref in hub_references %}
      - name: hk_{{ hub_ref }}
        description: "Foreign key to {{ hub_ref }}"
        data_tests:
          - not_null
      {%- endfor %}
      {%- for payload in payload_columns %}
      - name: {{ payload }}
        description: "Payload column"
      {%- endfor %}
      - name: ldts
        description: "Load date timestamp"
      - name: rsrc
        description: "Record source"
